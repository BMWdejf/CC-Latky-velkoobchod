# =============================================================================
# .env.example — šablona ENV proměnných pro B2B Commerce Platform
# =============================================================================
# Zkopíruj tento soubor jako .env.local a doplň skutečné hodnoty.
# .env.local NIKDY necommituj — je v .gitignore
# Tento soubor (.env.example) JE v gitu — obsahuje pouze prázdné klíče.
# =============================================================================


# -----------------------------------------------------------------------------
# NEON DATABASE
# Neon Console → váš projekt → Connection Details → Connection string
# Použij "Pooled connection" (port 6543) pro produkci a vývoj
# Použij "Direct connection" (port 5432) pro db:migrate
# -----------------------------------------------------------------------------

DATABASE_URL=
DATABASE_URL_UNPOOLED=


# -----------------------------------------------------------------------------
# NEON AUTH (Better Auth)
# Neon Console → váš projekt → Auth → Configuration
# -----------------------------------------------------------------------------

# Auth endpoint URL — z Neon Console → Auth → Auth URL
NEON_AUTH_BASE_URL=

# Cookie encryption secret — minimálně 32 znaků
# Generuj: openssl rand -base64 32
# POZOR: Každé prostředí (dev/staging/prod) má JINÝ secret
NEON_AUTH_COOKIE_SECRET=
NEON_JWKS_URL=


# -----------------------------------------------------------------------------
# FIGMA MCP
# Figma → Account Settings → Security → Personal access tokens
# Název tokenu doporučujeme: "Claude Code MCP - <název projektu>"
# -----------------------------------------------------------------------------

FIGMA_ACCESS_TOKEN=
FIGMA_URL_PROJECT=

# -----------------------------------------------------------------------------
# TESTOVACÍ ÚČTY (pouze lokální vývoj a CI/CD)
# Tyto účty musí existovat v NeonAuth testovací branch
# NIKDY nepoužívej produkční účty pro testy
# -----------------------------------------------------------------------------

TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

TEST_CUSTOMER_EMAIL=
TEST_CUSTOMER_PASSWORD=

# -----------------------------------------------------------------------------
# GITHUB (pro integraci s GitHubem, např. pro automatické nasazení z repozitáře)
# Vytvoř Personal Access Token v GitHubu → Settings → Developer settings → Personal access tokens
# Název tokenu doporučujeme: "Claude Code MCP - <název projektu>" 
# -----------------------------------------------------------------------------
GITHUB_ACCESS_TOKEN=
GITHUB_REPO_URL=

# =============================================================================
# PŘEHLED: které proměnné kam patří
# =============================================================================
#
# Proměnná                  | .env.local | GitHub Secrets | Vercel
# --------------------------|------------|----------------|-------
# DATABASE_URL              |     ✅     |       ✅       |   ✅
# DATABASE_URL_UNPOOLED     |     ✅     |       ✅       |   ✅
# NEON_AUTH_BASE_URL        |     ✅     |       ✅       |   ✅
# NEON_AUTH_COOKIE_SECRET   |     ✅     |       ✅       |   ✅
# FIGMA_ACCESS_TOKEN        |     ✅     |       ❌       |   ❌
# TEST_ADMIN_EMAIL          |     ✅     |       ✅       |   ❌
# TEST_ADMIN_PASSWORD       |     ✅     |       ✅       |   ❌
# TEST_CUSTOMER_EMAIL       |     ✅     |       ✅       |   ❌
# TEST_CUSTOMER_PASSWORD    |     ✅     |       ✅       |   ❌
#
# Pozn.: GitHub Secrets a Vercel používají hodnoty pro TEST branch (CI/CD)
#        resp. produkční branch (Vercel) — nikdy nekřížit!
# =============================================================================
